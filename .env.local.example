NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional but strongly recommended for serious India coverage.
# Use either a Mappls static REST key/access token OR OAuth client credentials.
# Keep these server-side. Do NOT prefix them with NEXT_PUBLIC_.
MAPPLS_ACCESS_TOKEN=
MAPPLS_REST_KEY=
MAPPLS_STATIC_KEY=
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=
MAPMYINDIA_ACCESS_TOKEN=
MAPMYINDIA_REST_KEY=
MAPMYINDIA_STATIC_KEY=
MAPMYINDIA_CLIENT_ID=
MAPMYINDIA_CLIENT_SECRET=

# Optional but strongly recommended for worldwide POI coverage.
# Foursquare Places API uses Authorization: <API_KEY> on the server route.
# Keep this server-side. Do NOT prefix with NEXT_PUBLIC_.
FOURSQUARE_API_KEY=
FSQ_API_KEY=

# Optional, used by OpenStreetMap/Nominatim place-search proxy.
# Add an email before real public traffic so OSM operators can contact you.
NOMINATIM_EMAIL=

# No paid Google Maps / Google Places API key is needed.
# Google Maps is used only through no-key external URL links for directions/search.


# Optional respectful ad/sponsor slot controls.
# Set NEXT_PUBLIC_SHOW_ADS=false to hide all ad boxes.
NEXT_PUBLIC_SHOW_ADS=true
NEXT_PUBLIC_AD_LABEL=Sponsored
NEXT_PUBLIC_AD_HEADLINE=Community sponsor
NEXT_PUBLIC_AD_BODY=A respectful sponsor space that helps keep verified jamaat data free for users.
NEXT_PUBLIC_AD_CTA=Learn more
NEXT_PUBLIC_AD_URL=

# Optional Google Places discovery.
# This is the only way to bring the same Google Maps mosque POIs into the app.
# It is server-side and may be billed by Google; no key is needed for Google Maps navigation URLs.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_TEXT_FALLBACK=false

# Firebase Cloud Messaging web push notifications.
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
